# MongoDB connection (backend and containerized DB)
# Default: mongodb://localhost:27017 (no auth). Set if using a different host/port or auth.
# MONGODB_URI=mongodb://localhost:27017

# Optional: enable auth in the containerized DB (only used when set; then include in MONGODB_URI)
# MONGO_INITDB_ROOT_USERNAME=
# MONGO_INITDB_ROOT_PASSWORD=

# Optional: isolate Compose project for CI/parallel runs (e.g. COMPOSE_PROJECT_NAME=issue-tracker-${CI_JOB_ID})
# COMPOSE_PROJECT_NAME=
